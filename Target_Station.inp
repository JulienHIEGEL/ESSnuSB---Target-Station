* ..+....1....+....2....+....3....+....4....+....5....+....6....+....7...
*
TITLE
ESSnuSB Plus One Magnetic Horn
*
#define SampleDose
*
DEFAULTS                                                              PRECISIO
*
* Beam definition
* ---------------
*  Gaussian beam, (sigma_x, sigma_y) = (0.05cm, 0.1cm)
BEAM            -2.5         0         0                   0       1.0PROTON
BEAMPOS            0         0         0       0.0       0.0
SOURCE            29
OPEN              29                                                  OLD
../../../BeamProfTarget.txt
TIME-CUT     1000000
#include Others_inp/ESSnuSBp_ROTDEFI.inp
*
* Geometry
* --------
GEOBEGIN                                                              COMBNAME
    0    0          
#include Others_inp/ESSnuSBp_bodies.inp
END
#include Others_inp/ESSnuSBp_regions.inp
END
#include Others_inp/ESSnuSBp_lattices.inp
GEOEND
*
* Material definitions
* --------------------
MATERIAL         19.  -39.0983     0.862                              POTASSIU
MATERIAL         24.  -51.9961      7.18                              CHROMIUM
MATERIAL         25.-54.938049      7.21                              MANGANES
MATERIAL         15.-30.973761      1.82                              PHOSPHO
MATERIAL         16.   -32.066      2.07                              SULFUR
MATERIAL         22.                  3.                              TITAN60
* Steel316LN
* Stainless steel AISI316LN
MATERIAL                             7.8                              SS316LN
COMPOUND    -0.67145      IRON    -0.185  CHROMIUM   -0.1125    NICKELSS316LN
COMPOUND       -0.02  MANGANES     -0.01   SILICON  -0.00045   PHOSPHOSS316LN
COMPOUND     -0.0003    SULFUR   -0.0003    CARBON                    SS316LN
*
* Concrete portland
* -----------------
MATERIAL                             2.3                              PORTLAND
COMPOUND       -0.01  HYDROGEN    -0.001    CARBON -0.529107    OXYGENPORTLAND
COMPOUND      -0.016    SODIUM    -0.002  MAGNESIU -0.033872  ALUMINUMPORTLAND
COMPOUND   -0.337021   SILICON    -0.013  POTASSIU    -0.044   CALCIUMPORTLAND
COMPOUND      -0.014      IRON                                        PORTLAND
#include Others_inp/ESSnuSBp_materials.inp
MAT-PROP           1                        VACUUM  @LASTMAT          USERDIRE
* * Activation calculations
* -----------------------
PHYSICS           3.                                                  EVAPORAT
PHYSICS           1.                                                  COALESCE
PHYSICS                                                               PEATHRES
*
* Electromagnetic thresholds
* --------------------------
*         prompt     decay
*  e+/-   10 MeV    100keV
*  gamma   5 MeV     50keV
EMFCUT        -1E-05      5E-5        1.    VACUUM  @LASTMAT          PROD-CUT
EMFCUT        -1E-05      5E-5             BLKBODY  @LASTREG
RADDECAY           1                                   99999
DCYTIMES           1        60      3600        -1
IRRPROFI    17280000   3.12E15
*
* Photonuclear interactions
* -------------------------
PHOTONUC          1.                      BLCKHOLE  @LASTMAT
*
* Hadronic thresholds
* -------------------
PART-THR    -10.0E-6    PROTON   APROTON
PART-THR    -10.0E-6  ANEUTRON  @LASTPAR
*Score the Energy in all regions
SCORE           DOSE                        ENERGY
USRBIN            10     PION+       -98       350       350      1700Pip
USRBIN          -900      -350         0       625       350       850 &
USRBIN            10    ENERGY       -97       350       350      1700E
USRBIN          -900      -350         0       625       350       850 &
USRBIN            10    PROTON       -99       350       350      1700Proton
USRBIN          -900      -350         0       625       350       850 &
*
* ..+....1....+....2....+....3....+....4....+....5....+....6....+....7....+....8
RANDOMIZ           1         1
START           2000                                     0.0
